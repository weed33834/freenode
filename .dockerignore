# 通用 Docker 构建忽略规则，根 context 用（backend/Dockerfile 的 context 是 ..）
# 避免把无关大目录拷进镜像，让 build context 小、缓存命中高。

# VCS
.git/
.gitignore
.gitattributes
.githooks/

# CI / 元数据
.github/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Python 缓存与虚拟环境
**/__pycache__/
**/*.py[cod]
.venv/
venv/
*.egg-info/

# 前端构建产物（容器内自己 build）
web/.next/
web/dist/
web/out/
web/node_modules/
docs-site/node_modules/
docs-site/.vitepress/cache/
docs-site/.vitepress/dist/

# 运行时数据
data/
backend/data/
*.db
*.db-journal
*.db-wal
*.db-shm
nodes/*.tmp

# 日志
*.log
logs/

# 文档与配置（不需要进镜像）
docs-site/
landing/
*.md
!README.md
LICENSE
VERSION

# 本地环境
*.env
.env.*
!/.env.example
!backend/.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
