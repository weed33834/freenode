# FreeNode Caddyfile — reverse proxy with automatic HTTPS
#
# Replace freenode.example.com with your actual domain.
# Caddy will automatically obtain and renew Let's Encrypt certificates.

freenode.example.com {
    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Compression
    encode zstd gzip

    # API requests → FastAPI backend
    @api path /api/* /docs /redoc /openapi.json
    reverse_proxy @api backend:8000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # Static subscription files (served directly for high throughput)
    @subs path /nodes/*
    handle @subs {
        root * /srv/nodes
        file_server
    }

    # 其余 → 前端 Next.js
    reverse_proxy web:3000

    # Access log
    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 7
        }
        format json
    }
}
