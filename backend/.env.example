# =============================================================================
# FreeNode 后端环境变量模板
#
# 用法：
#   cp .env.example .env
#   然后编辑 .env，至少设置下面标注【必填】的两项。
#
# 生成强随机值：
#   ADMIN_API_KEY:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   SECRET_KEY_HEX: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ─── 应用 ───────────────────────────────────────────────
# 生产必须 false。true 时：调度器不启动 + /docs /openapi.json 暴露 + 详细错误。
FREENODE_DEBUG=false
# 应用名（仅展示用）
FREENODE_APP_NAME=FreeNode API
# API 路由前缀，一般不用改
FREENODE_API_PREFIX=/api
# CORS 允许的 origin，逗号分隔。
# Caddy 同源反代时留空即可；如需跨域填完整 origin：
#   FREENODE_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
FREENODE_CORS_ORIGINS=

# ─── 数据库 ─────────────────────────────────────────────
# 默认 SQLite（容器内 /app/backend/data/freenode.db，卷 backend_data 持久化）。
# 节点 > 5k 或验证 worker > 50 时切 PostgreSQL：
#   1. docker-compose.yml 已内置 postgres:16-alpine 服务
#   2. 把下面 sqlite 那行注释掉，取消注释 postgresql 那行
#   3. 同时改 POSTGRES_PASSWORD 为强密码，与连接串里的一致
FREENODE_DATABASE_URL=sqlite:///data/freenode.db
# FREENODE_DATABASE_URL=postgresql+asyncpg://freenode:change_me@postgres:5432/freenode

# PostgreSQL 服务凭据（仅切到 PG 时需要，sqlite 部署可忽略）
POSTGRES_USER=freenode
POSTGRES_PASSWORD=change_me
POSTGRES_DB=freenode

# ─── 管理接口鉴权【必填】──────────────────────────────
# /api/admin/* 端点的 API Key，空 = admin 端点禁用（生产绝不能空）。
# 客户端用 X-API-Key 头携带此值。
FREENODE_ADMIN_API_KEY=

# ─── 节点密钥加密【必填】──────────────────────────────
# 32 字节 hex（64 个十六进制字符）的 AES-GCM 密钥，用于加密节点 auth_secret。
# 空 = 不加密（仅开发可接受，生产必须设）。
# 生成：python3 -c "import secrets; print(secrets.token_hex(32))"
FREENODE_SECRET_KEY_HEX=

# ─── 流水线调优 ─────────────────────────────────────────
# 输出文件最大节点数
FREENODE_MAX_NODES=800
# 输出文件最大代理数
FREENODE_MAX_PROXIES=300
# 是否做 TCP 连通性验证（false = 只抓不验，节点质量无保证）
FREENODE_VERIFY_NODES=true
# 单节点验证超时（秒）
FREENODE_VERIFY_TIMEOUT=5
# 并发验证 worker 数（小服务器 1G 内存建议降到 20）
FREENODE_VERIFY_WORKERS=50
# 是否启用 GeoIP 定位（需要额外装 geoip2 数据库，默认关）
FREENODE_GEO_ENABLED=false
# 抓取并发数
FREENODE_CRAWL_WORKERS=16

# ─── 调度器（cron，UTC 时区，空 = 关闭）──────────────
# 全量刷新：crawl + parse + verify + upsert + publish（每天 03:00 UTC）
FREENODE_SCHEDULE_FULL_REFRESH=0 3 * * *
# 存活节点复验（每 30 分钟）
FREENODE_SCHEDULE_VERIFY_ALIVE=*/30 * * * *
# 死节点复验给复活机会（每 6 小时）
FREENODE_SCHEDULE_VERIFY_DEAD=0 */6 * * *
# 清理 90 天前的 NodeCheck 历史（每天 04:00 UTC）
FREENODE_SCHEDULE_CLEANUP=0 4 * * *

# ─── 路径（容器内一般不用改）──────────────────────────
FREENODE_SOURCES_CONFIG_PATH=/app/config/sources.json
FREENODE_NODES_OUTPUT_DIR=/app/nodes
