# FreeNode 流水线（scripts/）环境变量示例。
# 复制为 .env 并按需调整。真实 .env 不要提交。
# 后端 API 服务的配置见 backend/.env.example。

# ─── 日志 ───────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
FREENODE_LOG_LEVEL=INFO

# ─── 节点验证 ───────────────────────────────────────────────────────
# 是否在 update.py 时启用 TCP 连通性校验（耗时更长，过滤失效节点）
FREENODE_VERIFY_NODES=true
# 单个节点 TCP 连接超时（秒）
FREENODE_VERIFY_TIMEOUT=5
# 并发验证线程数
FREENODE_VERIFY_WORKERS=50

# ─── 输出规模 ───────────────────────────────────────────────────────
# 输出中保留的最大节点链接数（vmess/vless/ss/trojan）
# 默认值与 backend/app/config.py 保持一致
FREENODE_MAX_NODES=800
# 输出中保留的最大 HTTP(S)/SOCKS4/SOCKS5 代理数
FREENODE_MAX_PROXIES=300

# ─── 抓取并发 ───────────────────────────────────────────────────────
# 并发源抓取数；留空则自动取 min(16, 启用源数量)
FREENODE_CRAWL_WORKERS=

# ─── SSRF 白名单 ────────────────────────────────────────────────────
# crawler 允许的额外域名（逗号分隔）。默认放行 raw.githubusercontent.com / gitcode.com / api.gitcode.com
FREENODE_ALLOWED_HOSTS=raw.githubusercontent.com,gitcode.com,api.gitcode.com

# ─── 地区分组 ───────────────────────────────────────────────────────
# 是否启用 GeoIP 地区分组（需要 geo 缓存数据，本地可选）
FREENODE_GEO_ENABLED=false
