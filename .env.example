# FreeNode pipeline (scripts/) env var example.
# Copy to .env and adjust as needed; never commit a real .env.

# Log level: DEBUG / INFO / WARNING / ERROR
FREENODE_LOG_LEVEL=INFO

# Run TCP connectivity check? (slower, filters dead nodes)
FREENODE_VERIFY_NODES=true
# Per-node connect timeout (seconds)
FREENODE_VERIFY_TIMEOUT=5
# Concurrent verification workers
FREENODE_VERIFY_WORKERS=50

# Max node links to keep in output (vmess/vless/ss/trojan)
FREENODE_MAX_NODES=800
# Max HTTP(S)/SOCKS4/SOCKS5 proxies to keep in output
FREENODE_MAX_PROXIES=300

# Concurrent sources to crawl; empty = min(16, enabled source count)
FREENODE_CRAWL_WORKERS=

# Extra hosts the crawler may reach (SSRF guard), comma-separated
FREENODE_ALLOWED_HOSTS=raw.githubusercontent.com,gitcode.com,api.gitcode.com

# Group output by region? (requires GeoIP data)
FREENODE_GEO_ENABLED=false
