#!/usr/bin/env bash
# pre-push 钩子：推送前跑一遍质量门禁。
# 启用方法（每个开发者做一次）：
#   git config core.hooksPath .githooks
# 临时跳过：git push --no-verify

set -euo pipefail

echo "[pre-push] 跑质量门禁……"

# 1. 密钥扫描（最快，先跑）
bash scripts/check_secrets.sh

# 2. 全量检查（lint + test + test-backend + tsc + lint-web）
make check

echo "[pre-push] 全部通过，继续推送。"
